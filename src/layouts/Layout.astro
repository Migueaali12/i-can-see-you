---
import '@/styles/global.css'
import '@fontsource/nanum-pen-script'
import '@fontsource/lxgw-wenkai-mono-tc'
import SiteHeader from '@/components/layout/SiteHeader.astro'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'I can see you | Demo de deteccion',
  description = 'Simulador visual de senales de distraccion detectables por el navegador.'
} = Astro.props as Props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Header -->
    <SiteHeader />

    <!-- Content -->
    <slot />

    <!-- Footer -->
    <footer class="site-footer">
      <span class="site-footer__claim">TE ESTOY MIRANDO.</span>
      <nav aria-label="Links del pie de pagina">
        <ul>
          <li><a href="#">Privacidad</a></li>
          <li><a href="#">Manual</a></li>
          <li><a href="#">Opt-out</a></li>
        </ul>
      </nav>
    </footer>
  </body>
</html>

<style>
  .fixed-disclaimer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 40;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-variant);
    border-top: 2px solid #000;
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-on-surface-variant);
  }

  .fixed-disclaimer .material-symbols-outlined {
    font-size: 1rem;
  }

  .site-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: #fff;
    border: 2px solid #000;
    border-left: none;
    border-right: none;
    border-bottom: none;
    border-top: 4px solid #000;
    margin-top: 4rem;
  }

  .site-footer__claim {
    font-weight: 700;
    font-size: 0.95rem;
    color: #000;
  }

  .site-footer nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
  }

  .site-footer nav a {
    font-family: monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-secondary);
  }

  .site-footer nav a:hover {
    font-style: italic;
  }
</style>

---
import { DoodleCard } from "@/components/ui/Card"

const detectedItems = [
  "Tab visibility changes (tab switch).",
  "Window focus loss and recovery.",
  "Fullscreen exit and prolonged inactivity.",
]

const notDetectedItems = [
  "Applications open outside the browser.",
  "Exact content of other system windows.",
  "What you ate for breakfast this morning.",
]
---

<section
  class='grid grid-cols-1 min-[700px]:grid-cols-2 gap-16 w-[min(900px,calc(100%-3rem))] mx-auto pt-4 pb-8'
>
  <div class='animate-in fade-in slide-in-from-bottom-4' style='animation-delay:150ms'>
    <DoodleCard
      dashedBorder
      corner='scan'
      title='What I can detect'
      listItems={detectedItems}
    />
  </div>
  <div class='animate-in fade-in slide-in-from-bottom-4' style='animation-delay:250ms'>
    <DoodleCard
      dashedBorder
      corner='eye-off'
      title="What I can't detect"
      listItems={notDetectedItems}
      listMuted
    />
  </div>
</section>

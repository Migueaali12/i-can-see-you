---
import MascotEyes from "@/components/mascot/MascotEyes"
import HeroCtaButton from "@/components/landing/HeroCtaButton"
import { useTranslations } from "@/i18n/utils"
import type { Lang } from "@/i18n/ui"

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
  class='mx-auto flex max-w-195 flex-col items-center px-6 pt-[clamp(1rem,4vh,3rem)] pb-[clamp(1rem,3vh,2rem)] text-center shrink-0'
>
  <div class='mb-[clamp(1rem,3vh,2rem)]'>
    <MascotEyes client:load size='mascot--hero' />
  </div>

  <h1
    class='font-display mb-[clamp(0.5rem,2vh,1.5rem)] text-[clamp(2.5rem,6vw,4rem)] leading-[1.05] font-bold tracking-[-0.02em] text-(--color-primary)'
  >
    {t('common.brand')}
  </h1>

  <p
    class='mb-[clamp(0.5rem,1vh,1rem)] border-b-2 border-dashed border-(--color-outline-variant) pb-[clamp(0.5rem,2vh,1.5rem)] text-[clamp(1.1rem,2vw,1.1rem)] leading-[0.9] font-semibold text-(--color-secondary)'
  >
    {t('landing.heroTagline')}
  </p>

  <p class='mt-[clamp(0.5rem,2vh,1.5rem)] text-[0.95rem] leading-normal w-64l max-w-full text-(--color-secondary)'>
    {t('landing.heroDescription')}
  </p>

  <div class='mt-[clamp(1rem,3vh,4rem)] mb-5'>
    <HeroCtaButton client:load lang={lang} />
  </div>
</section>

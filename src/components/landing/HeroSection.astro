---
import Button from "@/components/ui/Button.astro"
---

<section
  class='mx-auto flex max-w-[780px] flex-col items-center px-6 pt-16 pb-12 text-center'
>
  <div
    class='mb-8 cursor-crosshair select-none text-[7.5rem] leading-none transition-transform duration-300 ease-out hover:scale-110'
  >
    <span aria-label='Ojos observando' role='img'>👀</span>
  </div>

  <h1
    class='font-display mb-6 text-[clamp(2.5rem,6vw,4rem)] leading-[1.05] font-bold tracking-[-0.02em] text-black'
  >
    I can see you
  </h1>

  <p
    class='mb-12 border-b-2 border-dashed border-(--color-outline-variant) pb-4 text-[clamp(1.1rem,2vw,1.4rem)] leading-[1.3] font-semibold text-(--color-secondary)'
  >
    Detección de distracciones en el navegador
  </p>

  <div class='flex flex-wrap justify-center gap-4'>
    <Button href='/demo' icon='adjust'>Probar detección</Button>
  </div>
</section>

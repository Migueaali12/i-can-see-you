---
import MascotEyes from "@/components/mascot/MascotEyes"
import HeroCtaButton from "@/components/landing/HeroCtaButton"
---

<section
  class='mx-auto flex max-w-[780px] flex-col items-center px-6 pt-16 pb-12 text-center'
>
  <div class='mb-8'>
    <MascotEyes client:load size='mascot--hero' />
  </div>

  <h1
    class='font-display mb-6 text-[clamp(2.5rem,6vw,4rem)] leading-[1.05] font-bold tracking-[-0.02em] text-black'
  >
    I can see you
  </h1>

  <p
    class='mb-2 border-b-2 border-dashed border-(--color-outline-variant) pb-4 text-[clamp(1.1rem,2vw,1.4rem)] leading-[1.3] font-semibold text-(--color-secondary)'
  >
    60 seconds. That's all it takes. Try not to get distracted.
  </p>

  <p class='mt-4 text-[0.95rem] leading-[1.5] max-w-[520px] text-(--color-secondary)'>
    A free browser activity detector that shows exactly which signals your browser reveals when you lose focus — tab switches, window blur, fullscreen exits, and more. No camera. No server. 100% local.
  </p>

  <div class='mt-8'>
    <HeroCtaButton client:load />
  </div>
</section>
---
import Layout from "@/layouts/Layout.astro"
import HeroSection from "@/components/landing/HeroSection.astro"
import CoverageSection from "@/components/landing/CoverageSection.astro"
import { getLangFromUrl, useTranslations } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": t('seo.faq.whatIsQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.faq.whatIsA'),
      }
    },
    {
      "@type": "Question",
      "name": t('seo.faq.howWorksQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.faq.howWorksA'),
      }
    },
    {
      "@type": "Question",
      "name": t('seo.faq.realProctorQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.faq.realProctorA'),
      }
    },
    {
      "@type": "Question",
      "name": t('seo.faq.inactivityQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.faq.inactivityA'),
      }
    },
  ]
}

const webAppStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": t('seo.webAppName'),
  "description": t('seo.webAppDescription'),
  "url": "https://icanseeyou.dev",
  "applicationCategory": t('seo.webAppCategory'),
  "operatingSystem": t('seo.webAppOS'),
  "browserRequirements": t('seo.webAppBrowserReq'),
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
---

<Layout
  title={t('seo.indexTitle')}
  description={t('seo.indexDescription')}
  keywords={t('seo.indexKeywords')}
  structuredData={[faqStructuredData, webAppStructuredData]}
>
  <main>
    <HeroSection lang={lang} />
    <CoverageSection lang={lang} />
  </main>
</Layout>

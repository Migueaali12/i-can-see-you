---
import Layout from "@/layouts/Layout.astro"
import PrivacyHero from "@/components/privacy/PrivacyHero.astro"
import PrivacyContent from "@/components/privacy/PrivacyContent.astro"
import { getLangFromUrl, useTranslations } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": t('seo.privacy.faq.cameraQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.privacy.faq.cameraA'),
      }
    },
    {
      "@type": "Question",
      "name": t('seo.privacy.faq.dataQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.privacy.faq.dataA'),
      }
    },
    {
      "@type": "Question",
      "name": t('seo.privacy.faq.apisQ'),
      "acceptedAnswer": {
        "@type": "Answer",
        "text": t('seo.privacy.faq.apisA'),
      }
    },
  ]
}
---

<Layout
  title={t('privacy.title')}
  description={t('privacy.description')}
  keywords={t('privacy.keywords')}
  structuredData={faqStructuredData}
>
  <main>
    <PrivacyHero lang={lang} />
    <PrivacyContent lang={lang} />
  </main>
</Layout>

---
import Layout from "@/layouts/Layout.astro"
import MascotEyes from "@/components/mascot/MascotEyes"
import DialogBubble from "@/components/demo/active-session/DialogBubble"
import Button from "@/components/ui/Button"
import { Home } from "lucide-react"
---

<Layout
  title="Page Not Found | I Can See You"
  description="This page doesn't exist. Head back to I Can See You to test your browser distraction signals."
  noindex
>
  <main class="flex flex-col items-center justify-center min-h-[calc(100dvh-150px)] px-4 py-16 text-center gap-6">
    <DialogBubble message="I looked everywhere, but this page is invisible." />
    <MascotEyes client:load size="mascot--md-small" />
    <h1 class="font-display text-[clamp(5rem,10vw,10rem)] font-semibold text-[#111111] leading-none">
      404
    </h1>
    <p class="font-body text-lg mb-6 text-[#444444] max-w-md leading-relaxed">
      This page went off the radar. Even my eyes can't detect it.
    </p>
    <Button href="/" size="lg">Go back home <Home/></Button>
  </main>
</Layout>

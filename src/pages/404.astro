---
import Layout from "@/layouts/Layout.astro"
import MascotEyes from "@/components/mascot/MascotEyes"
import Button from "@/components/ui/Button"
import { ArrowLeft } from "lucide-react"
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout
  title={t('404.title')}
  description={t('404.description')}
  noindex
>
  <main class="flex flex-col items-center justify-center min-h-[calc(100dvh-150px)] px-6 text-center">
    <MascotEyes
      size="mascot--md"
      expression="suspicious"
      className="mb-8"
      client:load
    />
    <h1 class="font-display text-6xl md:text-8xl text-(--color-on-card) mb-4">
      {t('404.heading')}
    </h1>
    <p class="text-(--color-secondary) text-base md:text-lg mb-8 max-w-md">
      {t('404.body')}
    </p>
    <Button href={getRelativeLocaleUrl(lang, '/')} variant="black" size="lg">
      {t('common.goBackHome')} <ArrowLeft size={20} />
    </Button>
  </main>
</Layout>
